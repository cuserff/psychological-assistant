# 后端 API 根地址（不要末尾斜杠）。本地开发可复制为 .env.development
VITE_API_BASE=http://localhost:3000

# 大模型是否尝试多模态（图文）请求。设为 false 或 0 时仅用纯文本（适合不支持视觉的模型，启动更快）
# VITE_LLM_VISION=false

# 流式回复在界面上的「打字」节奏。默认约每 36ms 显示 2 个字符；仅调大 REVEAL_MS 或调小 CHARS 可放慢。
# VITE_STREAM_REVEAL_MS=50
# VITE_STREAM_CHARS_PER_TICK=1
# 任一为 0 则关闭节流（与接口分包同速）
# VITE_STREAM_REVEAL_MS=0
