# 后端 API 根地址（不要末尾斜杠）。本地开发可复制为 .env.development
VITE_API_BASE=http://localhost:3000

# 语音输入：默认 browser（Web Speech）。需要服务端讯飞听写时设为 backend
# VITE_VOICE_STT_MODE=browser
# VITE_VOICE_STT_MODE=backend

# 大模型是否尝试多模态（图文）请求。设为 false 或 0 时仅用纯文本（适合不支持视觉的模型，启动更快）
# VITE_LLM_VISION=false

# 流式回复「打字」节奏（与语音播报不同步时：MODE=voice 放慢文字，或 TTS_PLAYBACK_RATE>1 加快朗读）
# 预设：normal | slow/voice/tts/sync | fast | off
# VITE_STREAM_REVEAL_MODE=voice
# 显式覆盖（优先于 MODE）：12～280 ms、每拍 1～24 字；任一为 0 则关闭节流
# VITE_STREAM_REVEAL_MS=50
# VITE_STREAM_CHARS_PER_TICK=1
# VITE_STREAM_REVEAL_MS=0

# TTS：浏览器播放倍速（默认 1，约 0.85～1.5）。1.2 可明显缩短听完时间
# VITE_TTS_PLAYBACK_RATE=1.2
# 讯飞合成语速 0～100（默认后台 50；略大可略加快成片）
# VITE_TTS_SPEED=58
