# ==================== 服务端基础配置 ====================
# 后端端口（前端 VITE_API_BASE 需要与之匹配）
PORT=3000

# JWT 密钥（生产环境务必改成强随机值）
JWT_SECRET=please-change-me

# ==================== LLM（讯飞 MaaS） ====================
# Bearer 格式，来自讯飞 MaaS 控制台
XUNFEI_API_KEY=your_maas_api_key

# 可选：模型与网关
XUNFEI_MAAS_MODEL=xopqwen35v35b
XUNFEI_MAAS_HOST=maas-api.cn-huabei-1.xf-yun.com
XUNFEI_MAAS_PATH=/v2/chat/completions

# ==================== 在线 TTS（服务端转发） ====================
# 与控制台「在线语音合成-流式版」一致时请用 xunfei-ws；旧版 HTTP 用 xunfei-webapi
TTS_PROVIDER=xunfei-ws

# 流式发音人 vcn（控制台「发音人授权」里的编码，如讯飞小燕 x4_xiaoyan）
XUNFEI_TTS_VCN=x4_xiaoyan

# 旧版 HTTP 地址（仅 TTS_PROVIDER=xunfei-webapi 时生效）
XUNFEI_TTS_HOST=api.xfyun.cn
XUNFEI_TTS_PATH=/v1/service/v1/tts

# 讯飞密钥：流式 WebSocket 需 APPID + APIKey + APISecret（控制台该服务页）
XUNFEI_TTS_APP_ID=your_app_id
XUNFEI_TTS_API_KEY=your_api_key
XUNFEI_TTS_API_SECRET=your_api_secret

# ==================== 语音转写 STT（实时 /ws/stt + 短音频 POST /api/voice/stt） ====================
# xunfei-iat-ws：讯飞「语音听写」流式版（IAT，需 APPID+APIKey+APISecret）
# xunfei-rtasr-ws：讯飞「实时语音转写标准版」（仅需 APPID+APIKey；短音频 POST 仍需另配听写三要素，见下）
# 勿将真实密钥提交 Git，仅写在本机 backend/.env
STT_PROVIDER=xunfei-iat-ws
# STT_MAX_AUDIO_BYTES=2097152
# XUNFEI_STT_WS_HOST=iat-api.xfyun.cn
# XUNFEI_STT_WS_PATH=/v2/iat
# XUNFEI_STT_APP_ID=
# XUNFEI_STT_API_KEY=
# XUNFEI_STT_API_SECRET=
# 听写业务参数（/ws/stt 与 POST STT 共用）
# XUNFEI_STT_LANGUAGE=zh_cn
# XUNFEI_STT_DOMAIN=iat
# XUNFEI_STT_ACCENT=mandarin
# 仅支持 8000 或 16000（PCM L16）
# XUNFEI_STT_SAMPLE_RATE=16000

# 实时转写 RTASR（STT_PROVIDER=xunfei-rtasr-ws 时必填；与控制台「实时语音转写标准版」一致）
# XUNFEI_RTASR_APP_ID=
# XUNFEI_RTASR_API_KEY=
# 可选：语种 / 领域，见讯飞 RTASR 文档
# XUNFEI_RTASR_LANG=
# XUNFEI_RTASR_PD=

# ==================== 实时 STT WebSocket（/ws/stt，JSON：start → audio → stop） ====================
# 长时间无 audio 自动结束（毫秒）；与客户端分片节奏独立，仅防挂死
# STT_WS_IDLE_TIMEOUT_MS=15000
# 连接上游听写 WS 的最长等待（毫秒）
# STT_WS_UPSTREAM_CONNECT_MS=10000
# 单路会话最大时长（毫秒），超时发 error 并等价 stop
# STT_WS_UPSTREAM_SESSION_MS=120000
# 客户端 stop 后等待上游 final 帧（毫秒）
# STT_WS_STOP_WAIT_MS=12000
# 上行 PCM 分片字节数（16k 官方建议 1280）
# STT_WS_PCM_FRAME_BYTES=1280

# 未单独配置 XUNFEI_STT_* 时，APP_ID/API_KEY 可回退到 XUNFEI_RTASR_*（APISecret 仍须听写或 TTS）
# XUNFEI_RTASR_API_SECRET=

